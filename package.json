{
  "name": "prompt-maestro",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:generate": "turbo db:generate",
    "db:deploy": "turbo db:deploy",
    "build:web": "turbo build --filter=@prompt-maestro/web",
    "build:backend": "turbo build --filter=@prompt-maestro/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "latest"
  }
}
