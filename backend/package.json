{
  "name": "@prompt-maestro/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run db:generate && tsc",
    "start": "npm run db:deploy && node dist/index.js",
    "db:generate": "prisma generate --schema=../packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../packages/database/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=../packages/database/prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio --schema=../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
